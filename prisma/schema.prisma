generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                           String                 @id @default(cuid())
  customerName                 String
  companyName                  String?
  phone                        String
  email                        String?
  kakaoId                      String?
  industry                     String
  boxType                      String
  widthMm                      Int?
  depthMm                      Int?
  heightMm                     Int?
  quantityRange                String
  printOption                  String
  finishingOptions             String?
  desiredDeliveryDate          DateTime?
  budgetRange                  String?
  referenceNote                String?
  message                      String?
  packageType                  String?
  packageStructure             String?
  quantity                     String?
  sizeInfo                     String?
  hasPhysicalProduct           String?
  hasDesignFile                String?
  hasDieline                   String?
  desiredDueDate               String?
  isUrgent                     Boolean                @default(false)
  readinessChecklist           String?
  readinessScore               Int?
  consultationNotes            String?
  consultationSummaryTitle     String?
  consultationSummaryOverview  String?
  consultationPriorityNotes    String?
  consultationMissingItems     String?
  consultationRiskNotes        String?
  consultationNextActions      String?
  consultationSummaryUpdatedAt DateTime?
  privacyConsent               Boolean                @default(false)
  privacyConsentAt             DateTime?
  marketingConsent             Boolean                @default(false)
  marketingConsentAt           DateTime?
  utmSource                    String?
  utmMedium                    String?
  utmCampaign                  String?
  utmTerm                      String?
  utmContent                   String?
  referrer                     String?
  landingPath                  String?
  sourceCaseSlug               String?
  sourceCaseTitle              String?
  estimatedUnitPriceMinKrw     Int?
  estimatedUnitPriceMaxKrw     Int?
  estimatedTotalPriceMinKrw    Int?
  estimatedTotalPriceMaxKrw    Int?
  estimateLabel                String?
  estimateDisclaimer           String?
  quoteComplexityLevel         String?
  quoteConfidenceLevel         String?
  quoteCalculationNotes        String?
  quoteMissingFields           String?
  estimatedPriceRange          String?
  leadScore                    Int                    @default(0)
  status                       String                 @default("NEW")
  nextFollowUpAt               DateTime?
  lastContactedAt              DateTime?
  salesNote                    String?
  quotedAt                     DateTime?
  orderConfirmedAt             DateTime?
  closedAt                     DateTime?
  confirmedOrderAmountKrw      Int?
  lostReason                   String?
  adminMemo                    String?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  quoteProposals               QuoteProposal[]
  quoteActivityLogs            QuoteActivityLog[]
  communicationLogs            LeadCommunicationLog[]
  salesTasks                   SalesTask[]

  @@index([createdAt])
  @@index([leadScore])
  @@index([status])
  @@index([nextFollowUpAt])
  @@index([lastContactedAt])
  @@index([quotedAt])
  @@index([orderConfirmedAt])
  @@index([closedAt])
  @@index([utmSource])
  @@index([utmCampaign])
  @@index([sourceCaseSlug])
}

model QuoteRule {
  id                           String               @id @default(cuid())
  name                         String               @unique
  isActive                     Boolean              @default(true)
  boxType                      String
  quantityRange                String
  minQuantity                  Int?
  maxQuantity                  Int?
  baseUnitPriceMinKrw          Int
  baseUnitPriceMaxKrw          Int
  sizeSmallThreshold           Int                  @default(500000)
  sizeMediumThreshold          Int                  @default(2000000)
  sizeLargeThreshold           Int                  @default(6000000)
  smallSizeMultiplier          Float                @default(0.9)
  mediumSizeMultiplier         Float                @default(1)
  largeSizeMultiplier          Float                @default(1.25)
  extraLargeSizeMultiplier     Float                @default(1.55)
  printNoneMultiplier          Float                @default(1)
  printOneColorMultiplier      Float                @default(1.08)
  printFullColorMultiplier     Float                @default(1.18)
  printFoilEmbossMultiplier    Float                @default(1.3)
  finishingBaseAddMinKrw       Int                  @default(0)
  finishingBaseAddMaxKrw       Int                  @default(0)
  complexityLowMultiplier      Float                @default(0.95)
  complexityNormalMultiplier   Float                @default(1)
  complexityHighMultiplier     Float                @default(1.18)
  complexityVeryHighMultiplier Float                @default(1.35)
  minOrderPriceKrw             Int                  @default(0)
  notes                        String?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  changeLogs                   QuoteRuleChangeLog[]

  @@index([isActive])
  @@index([boxType])
  @@index([quantityRange])
}

model QuoteProposal {
  id                            String                          @id @default(cuid())
  leadId                        String?
  lead                          Lead?                           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  proposalNumber                String                          @unique
  status                        String                          @default("DRAFT")
  revisionGroupId               String?
  revisionNumber                Int                             @default(1)
  parentProposalId              String?
  supersededByProposalId        String?
  isLatestRevision              Boolean                         @default(true)
  revisionReason                String?
  revisedFromCustomerResponseId String?
  supersededAt                  DateTime?
  title                         String
  customerNameSnapshot          String
  companyNameSnapshot           String?
  phoneSnapshot                 String?
  emailSnapshot                 String?
  kakaoIdSnapshot               String?
  boxType                       String
  industry                      String
  quantityLabel                 String?
  quantityCount                 Int?
  specificationSummary          String?
  productionNotes               String?
  deliveryEstimateText          String?
  paymentTerms                  String?
  validUntil                    DateTime?
  subtotalAmountKrw             Int                             @default(0)
  vatAmountKrw                  Int                             @default(0)
  totalAmountKrw                Int                             @default(0)
  vatIncluded                   Boolean                         @default(false)
  customerMessage               String?
  internalMemo                  String?
  basedOnEstimateLabel          String?
  basedOnUnitPriceMinKrw        Int?
  basedOnUnitPriceMaxKrw        Int?
  basedOnTotalPriceMinKrw       Int?
  basedOnTotalPriceMaxKrw       Int?
  estimateComparisonStatus      String?
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime                        @updatedAt
  items                         QuoteProposalItem[]
  shareLinks                    QuoteProposalShareLink[]
  customerResponses             QuoteProposalCustomerResponse[]
  activityLogs                  QuoteActivityLog[]
  salesTasks                    SalesTask[]

  @@index([leadId])
  @@index([status])
  @@index([proposalNumber])
  @@index([revisionGroupId])
  @@index([revisionNumber])
  @@index([parentProposalId])
  @@index([supersededByProposalId])
  @@index([isLatestRevision])
  @@index([revisedFromCustomerResponseId])
  @@index([createdAt])
  @@index([validUntil])
  @@index([boxType])
}

model QuoteProposalItem {
  id              String        @id @default(cuid())
  quoteProposalId String
  quoteProposal   QuoteProposal @relation(fields: [quoteProposalId], references: [id], onDelete: Cascade)
  sortOrder       Int           @default(0)
  itemName        String
  description     String?
  quantity        Int
  unitPriceKrw    Int
  amountKrw       Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([quoteProposalId])
  @@index([sortOrder])
}

model QuoteProposalShareLink {
  id                String                          @id @default(cuid())
  quoteProposalId   String
  quoteProposal     QuoteProposal                   @relation(fields: [quoteProposalId], references: [id], onDelete: Cascade)
  tokenHash         String                          @unique
  tokenPreview      String
  status            String                          @default("ACTIVE")
  expiresAt         DateTime
  revokedAt         DateTime?
  firstViewedAt     DateTime?
  lastViewedAt      DateTime?
  viewCount         Int                             @default(0)
  createdBy         String?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt
  customerResponses QuoteProposalCustomerResponse[]

  @@index([quoteProposalId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
}

model QuoteProposalCustomerResponse {
  id              String                 @id @default(cuid())
  quoteProposalId String
  quoteProposal   QuoteProposal          @relation(fields: [quoteProposalId], references: [id], onDelete: Cascade)
  shareLinkId     String
  shareLink       QuoteProposalShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  responseType    String
  message         String?
  responderName   String?
  createdAt       DateTime               @default(now())

  @@unique([shareLinkId])
  @@index([quoteProposalId])
  @@index([responseType])
  @@index([createdAt])
}

model QuoteActivityLog {
  id              String         @id @default(cuid())
  leadId          String?
  lead            Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quoteProposalId String?
  quoteProposal   QuoteProposal? @relation(fields: [quoteProposalId], references: [id], onDelete: SetNull)
  type            String
  actor           String
  message         String
  metadataJson    String?
  createdAt       DateTime       @default(now())

  @@index([leadId])
  @@index([quoteProposalId])
  @@index([type])
  @@index([actor])
  @@index([createdAt])
}

model LeadCommunicationLog {
  id             String    @id @default(cuid())
  leadId         String
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel        String
  direction      String
  summary        String
  detail         String?
  contactedAt    DateTime
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([leadId])
  @@index([channel])
  @@index([direction])
  @@index([contactedAt])
  @@index([nextFollowUpAt])
}

model SalesTask {
  id              String         @id @default(cuid())
  leadId          String?
  lead            Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quoteProposalId String?
  quoteProposal   QuoteProposal? @relation(fields: [quoteProposalId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  type            String         @default("GENERAL")
  priority        String         @default("NORMAL")
  status          String         @default("TODO")
  dueAt           DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  assignedTo      String?
  sourceType      String?
  sourceId        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([leadId])
  @@index([quoteProposalId])
  @@index([type])
  @@index([priority])
  @@index([status])
  @@index([dueAt])
  @@index([sourceType])
  @@index([sourceId])
  @@index([createdAt])
}

model QuoteRuleChangeLog {
  id                    String     @id @default(cuid())
  quoteRuleId           String?
  quoteRule             QuoteRule? @relation(fields: [quoteRuleId], references: [id], onDelete: SetNull)
  quoteRuleNameSnapshot String
  changeType            String
  beforeJson            String?
  afterJson             String?
  changeReason          String?
  changedBy             String?
  createdAt             DateTime   @default(now())

  @@index([quoteRuleId])
  @@index([changeType])
  @@index([createdAt])
}

model PortfolioCase {
  id                      String    @id @default(cuid())
  title                   String
  slug                    String    @unique
  status                  String    @default("DRAFT")
  featured                Boolean   @default(false)
  sortOrder               Int       @default(0)
  industry                String
  boxType                 String
  packageStructure        String?
  casePurpose             String?
  productName             String?
  clientName              String?
  isClientNamePublic      Boolean   @default(false)
  quantityRange           String?
  widthMm                 Int?
  depthMm                 Int?
  heightMm                Int?
  paperType               String?
  boardThickness          String?
  printOption             String?
  finishingOptions        String?
  mainImageUrl            String?
  mainImageAlt            String?
  imageCaption            String?
  imageUrls               String?
  shortDescription        String
  projectOverview         String?
  productionPoint         String?
  specificationSummary    String?
  seoTitle                String?
  seoDescription          String?
  tags                    String?
  publicApprovalConfirmed Boolean   @default(false)
  publicApprovalMemo      String?
  publicApprovedAt        DateTime?
  publicApprovalBy        String?
  publishedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([status])
  @@index([publicApprovalConfirmed])
  @@index([featured])
  @@index([sortOrder])
  @@index([publishedAt])
  @@index([industry])
  @@index([boxType])
  @@index([packageStructure])
  @@index([casePurpose])
}

model MarketingCost {
  id          String   @id @default(cuid())
  costDate    DateTime
  channel     String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  amountKrw   Int
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([costDate])
  @@index([channel])
  @@index([utmSource])
  @@index([utmCampaign])
}
